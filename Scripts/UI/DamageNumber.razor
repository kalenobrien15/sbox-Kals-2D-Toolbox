@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent

<root>
	<div class="damage-number" style="color: @TextColor; font-size: @(FontSize)px; font-smooth: never; image-rendering: pixelated;">
		@Text
	</div>
</root>

@code
{
	public string Text      { get; set; } = "";
	public string TextColor { get; set; } = "white";
	public float  FontSize  { get; set; } = 18f;

	protected override int BuildHash() => System.HashCode.Combine( Text, TextColor, FontSize );
}
