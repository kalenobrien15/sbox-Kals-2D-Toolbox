@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent

<root>
	<div class="hud-center">
	@if ( HeartMode )
	{
		<div class="hearts">
			@for ( int i = 0; i < (int)MaxHealth; i++ )
			{
				var index = i;
				var src       = index < (int)CurrentHealth ? FilledSrc : EmptySrc;
				var bgImage   = string.IsNullOrEmpty( src ) ? "" : $"background-image: url(\"{src}\");";
				<div class="heart" style="width: @(HeartSize)px; height: @(HeartSize)px; margin-right: @(HeartSpacing)px; @bgImage background-size: @(HeartSize)px @(HeartSize)px; background-repeat: no-repeat; image-rendering: pixelated;"></div>
			}
		</div>
	}
	else
	{
		<div class="bar-container" style="width: @(BarWidth)px; height: @(BarHeight)px; background-color: @BackgroundColor;">
			<div class="bar-fill" style="width: @( HealthPercent )%; height: 100%; background-color: @( HealthPercent <= LowThresholdPercent ? LowColor : FullColor );"></div>
			@if ( ShowText )
			{
				<label class="bar-text" style="position: absolute; left: 0; top: 0; width: 100%; height: 100%; text-align: center; color: @TextColor; font-family: @FontFamily; font-size: @(FontSize)px; font-smooth: never; image-rendering: pixelated; padding-top: @(TextPaddingTop)px; padding-left: @(TextPaddingLeft)px; padding-right: @(TextPaddingRight)px;">@((int)CurrentHealth) / @((int)MaxHealth)</label>
			}
		</div>
	}
	</div>
</root>

@code
{
	public float  CurrentHealth      { get; set; } = 100f;
	public float  MaxHealth          { get; set; } = 100f;
	public bool   HeartMode          { get; set; } = false;
	public bool   ShowText           { get; set; } = true;
	public float  LowHealthThreshold { get; set; } = 0.25f;
	public string BackgroundColor     { get; set; } = "rgba(0,0,0,0.5)";
	public string FullColor           { get; set; } = "rgb(80,200,80)";
	public string LowColor            { get; set; } = "rgb(220,50,50)";
	public string TextColor          { get; set; } = "white";
	public float  BarWidth           { get; set; } = 200f;
	public float  BarHeight          { get; set; } = 20f;
	public float  HeartSize          { get; set; } = 32f;
	public float  HeartSpacing       { get; set; } = 4f;
	public string FilledSrc          { get; set; } = "";
	public string EmptySrc           { get; set; } = "";
	public string FontFamily         { get; set; } = "";
	public float  FontSize           { get; set; } = 14f;
	public float  TextPaddingTop     { get; set; } = 0f;
	public float  TextPaddingLeft    { get; set; } = 0f;
	public float  TextPaddingRight   { get; set; } = 0f;

	private float HealthPercent       => MaxHealth > 0f ? ( CurrentHealth / MaxHealth ) * 100f : 0f;
	private float LowThresholdPercent => LowHealthThreshold * 100f;

	protected override int BuildHash()
	{
		var h1 = System.HashCode.Combine( CurrentHealth, MaxHealth, HeartMode, ShowText );
		var h2 = System.HashCode.Combine( BarWidth, BarHeight, FontFamily, FontSize );
		return System.HashCode.Combine( h1, h2, TextPaddingTop, HeartSpacing, BackgroundColor );
	}
}
